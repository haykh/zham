<?xml version="1.0" encoding="utf-8"?>
<!-- One widget row: city label + a self-updating TextClock (ticks every minute,
     hosted by the launcher, no app involvement). Kept as a single RemoteViews so the
     row lays out reliably as one Glance AndroidRemoteViews item. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">

    <TextView
        android:id="@+id/row_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="16sp" />

    <TextClock
        android:id="@+id/row_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp" />
</LinearLayout>
